---
import { env } from "cloudflare:workers";

import FileIcon from "phosphor-astro/FilePdf.astro";
import LockIcon from "phosphor-astro/LockFill.astro";
import Layout from "../layouts/Layout.astro";

interface FileRow {
	file_id: string;
	display_name: string | null;
	description: string | null;
	file_name: string;
	updated_at: string;
	password_hash: string | null;
}

const { results } = await env.library_data
	.prepare("SELECT * FROM files")
	.run<FileRow>();
---

<Layout>
	<div class="flex flex-col divide-y divide-gray-200">
		{
			results.map((file) => {
				return (
					<div class="py-6 flex flex-row gap-2">
						<div class="flex flex-col">
							<p class="text-xl">{file.display_name}</p>
							<div class="mb-2">
								<a
									class="inline-flex items-center gap-1 text-sm text-gray-500"
									href={"files/" + file.file_name}
									target="_blank"
								>
									<span>{file.file_name}</span>
									<span class="text-red-600 size-4">
										<FileIcon />
									</span>
									{file.password_hash && (
										<span class="text-yellow-500 size-3">
											<LockIcon />
										</span>
									)}
								</a>
							</div>
							<p>{file.description}</p>
						</div>
						<div class="ml-auto mr-0 shrink-0">
							<p class="text-sm">{file.updated_at}</p>
						</div>
					</div>
				);
			})
		}
	</div>
</Layout>
